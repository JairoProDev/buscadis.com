# ==================================
# ADIS AI - Environment Variables
# ==================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git!

# ----------------------------------
# Supabase Configuration
# ----------------------------------
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Bucket de imágenes de anuncios (default en prod: avisos-images)
NEXT_PUBLIC_ADISO_IMAGES_BUCKET=avisos-images

# ----------------------------------
# OpenAI Configuration (REQUIRED for ADIS AI)
# ----------------------------------
# Get your API key from: https://platform.openai.com/api-keys
# Cost estimate: ~$30-50/month for moderate usage
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ----------------------------------
# WhatsApp Business API (Optional)
# ----------------------------------
# Required for multi-channel support (Web + WhatsApp)
# Get these from: https://developers.facebook.com/apps
WHATSAPP_API_TOKEN=your-whatsapp-token-here
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id-here
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token-here
WHATSAPP_WEBHOOK_SECRET=your-webhook-secret-here

# ----------------------------------
# Application Settings
# ----------------------------------
# Base URL for your application (used for webhooks, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical public site URL (profiles, SEO, QR redirects after scan)
NEXT_PUBLIC_SITE_URL=https://www.buscadis.com
# Optional short domain for QR matrix only — must serve /q/* on Vercel. Leave empty to use SITE_URL.
# Do NOT use market.adis.lat / adis.lat until they are deployed and aliased in Vercel.
NEXT_PUBLIC_QR_SHORT_DOMAIN=

# ----------------------------------
# Optional: Feature Flags
# ----------------------------------
# Enable/disable specific AI features
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_SNAP_AND_SELL=true
NEXT_PUBLIC_ENABLE_VOICE_SEARCH=false

# ----------------------------------
# Buscadis mobile app (Expo WebView) — ingest & push
# ----------------------------------
# Optional shared secret; mobile app must send header X-Mobile-Ingest-Secret when set.
MOBILE_INGEST_SECRET=
# Send push from server: POST /api/mobile-push/send with Authorization: Bearer <secret>
MOBILE_PUSH_ADMIN_SECRET=
ADMIN_API_KEY=
# Expo push (recommended for production): https://expo.dev/accounts/<account>/settings/access-tokens
EXPO_ACCESS_TOKEN=
# Android App Links — SHA-256 cert fingerprint(s) from Play Console (comma-separated)
ANDROID_APP_LINKS_SHA256=
# Optional override (default com.adisplatforms.buscadis)
ANDROID_APP_PACKAGE_NAME=com.adisplatforms.buscadis
# iOS Universal Links — 10-char Apple Team ID + bundle id
APPLE_DEVELOPER_TEAM_ID=
IOS_APP_BUNDLE_ID=com.adisplatforms.buscadis

# ----------------------------------
# Promociones de anuncios (Mercado Pago)
# ----------------------------------
# Access token de producción o prueba: https://www.mercadopago.com.pe/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
# En desarrollo, usar checkout sandbox si tu token es de prueba
MERCADOPAGO_USE_SANDBOX=true
# Solo desarrollo local: activar promoción sin pago real (nunca en producción)
PROMOTION_DEV_BYPASS=false

# ----------------------------------
# Analytics & Observability
# ----------------------------------
# Google Analytics 4 — https://analytics.google.com (Web stream Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — https://clarity.microsoft.com (optional, consent-gated)
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Sentry — https://sentry.io (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
# Optional: upload source maps on Vercel builds
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Google Search Console verification — paste meta tag value in app/layout.tsx metadata.verification.google
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Vercel Web Analytics + Speed Insights: enable in Vercel Dashboard → Analytics (no env var required)

# ----------------------------------
# Development Settings
# ----------------------------------
# Set to 'development' for local work, 'production' for deployment
NODE_ENV=development

# Enable verbose logging for AI operations
AI_DEBUG_MODE=true
